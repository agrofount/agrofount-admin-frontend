# API origin for the Agrofount backend. Use HTTPS in production.
VITE_API_BASE_URL=https://api.example.com

# Socket.IO origin for realtime upload progress. Use WSS/HTTPS in production.
VITE_SOCKET_URL=wss://api.example.com

# Browser Google Maps key. Restrict this key by HTTP referrer and API in Google Cloud.
VITE_GOOGLE_MAPS_KEY=your_restricted_browser_key

# Public app origin used in links/callbacks. This is not a secret.
VITE_FRONTEND_URL=https://admin.example.com

# Default country identifier used by location/product flows.
VITE_COUNTRY_ID=

# Optional API request timeout in milliseconds.
VITE_API_TIMEOUT_MS=15000

# Admin MFA verification endpoint. Change this if the backend route differs.
VITE_ADMIN_MFA_VERIFY_PATH=/auth/admin/mfa/verify

# Legacy compatibility names still read by parts of the app during migration.
VITE_BACKEND_URL=https://api.example.com
VITE_WEBSOCKET_URL=wss://api.example.com
VITE_GOOGLE_MAPS_API_KEY=your_restricted_browser_key
